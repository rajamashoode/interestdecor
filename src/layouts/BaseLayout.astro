---
import '../styles/global.css';
const {
  title = 'InterestDecor — Home Decor, Gardening & DIY Inspiration',
  description = 'Discover beautiful home decor ideas, kitchen gardening tips, floral arrangements, and DIY craft inspiration on InterestDecor.com.',
  image = '/images/og-image.jpg',
  type = 'website',
} = Astro.props;
const site = 'https://interestdecor.com';
const canonical = new URL(Astro.url.pathname, site).toString();
const imageUrl = image.startsWith('http') ? image : new URL(image, site).toString();
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={imageUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>" />

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZK01DM6VVM"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-ZK01DM6VVM');
  </script>

  <script async defer src="//assets.pinterest.com/js/pinit.js"></script>
</head>
<body>

<!-- HEADER -->
<header class="site-header" role="banner">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="InterestDecor Home">
      <span class="logo-main">InterestDecor</span>
      <span class="logo-sub">Beautiful Living</span>
    </a>

    <nav class="main-nav" role="navigation" aria-label="Main navigation">
      <a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a>
      <a href="/categories/" class={currentPath.startsWith('/categories') ? 'active' : ''}>Categories</a>
      <a href="/about/" class={currentPath.startsWith('/about') ? 'active' : ''}>About</a>
      <a href="/contact/" class={currentPath.startsWith('/contact') ? 'active' : ''}>Contact</a>
    </nav>

    <div class="header-icons">
      <a href="https://pinterest.com/interestdecor" target="_blank" rel="noopener noreferrer" class="icon-btn" aria-label="Follow on Pinterest" title="Follow on Pinterest">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
      </a>
      <button class="icon-btn hamburger" id="menuToggle" aria-label="Open menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <button class="mobile-menu-close" id="menuClose" aria-label="Close menu">✕</button>
  <nav class="mobile-nav">
    <a href="/">Home</a>
    <a href="/categories/">Categories</a>
    <a href="/about/">About</a>
    <a href="/contact/">Contact</a>
  </nav>
</div>

<!-- PAGE CONTENT -->
<main id="mainContent">
  <slot />
</main>

<!-- FOOTER -->
<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo">InterestDecor</span>
        <p class="footer-desc">Your home should feel like you — beautiful, intentional, and full of life. That's what we're here to help create.</p>
        <div class="footer-social" role="list" aria-label="Social media links">
          <a href="https://pinterest.com/interestdecor" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" role="listitem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
          <a href="https://instagram.com/rajamashoodelahi" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram" role="listitem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <p class="footer-col-title">Explore</p>
        <nav class="footer-links">
          <a href="/">Home</a>
          <a href="/categories/">All Categories</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        </nav>
      </div>

      <div class="footer-col">
        <p class="footer-col-title">Topics</p>
        <nav class="footer-links">
          <a href="/categories/#home-decor">Home Decor</a>
          <a href="/categories/#kitchen-gardening">Kitchen Gardening</a>
          <a href="/categories/#floral-arrangements">Floral Arrangements</a>
          <a href="/categories/#diy-crafts">DIY & Crafts</a>
        </nav>
      </div>

      <div class="footer-col">
        <p class="footer-col-title">Newsletter</p>
        <p style="font-size:.83rem; line-height:1.7; margin-bottom:16px;">Weekly inspiration delivered to your inbox.</p>
        <form id="footerNewsletterForm" action="https://formspree.io/f/mqejnvve" method="POST" style="display:flex; flex-direction:column; gap:8px;">
          <input type="hidden" name="_subject" value="New InterestDecor footer newsletter signup" />
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />
          <input type="email" name="email" id="footerEmail" placeholder="your@email.com" style="padding:12px 14px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.15); color:white; font-family:var(--ff-body); font-size:.85rem; outline:none;" aria-label="Email for footer newsletter" required />
          <button type="submit" id="footerNlSubmit" style="padding:12px; background:var(--rose); border:none; color:white; font-size:.75rem; font-weight:500; letter-spacing:.1em; text-transform:uppercase; cursor:pointer;">Subscribe</button>
          <p id="footerNlMessage" style="display:none; font-size:.8rem; color:rgba(255,255,255,.75); line-height:1.6;">Thank you — you are subscribed.</p>
        </form>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© <span id="currentYear"></span> InterestDecor. All rights reserved.</p>
      <div class="footer-bottom-links">
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/terms-of-use/">Terms of Use</a>
        <a href="/disclaimer/">Disclaimer</a>
      </div>
    </div>
  </div>
</footer>

<script>
  // Year
  const yearEl = document.getElementById('currentYear');
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());

  // Mobile menu
  const menuToggle = document.getElementById('menuToggle');
  const menuClose  = document.getElementById('menuClose');
  const mobileMenu = document.getElementById('mobileMenu');

  function openMobileMenu() {
    mobileMenu?.classList.add('open');
    document.body.style.overflow = 'hidden';
    menuClose?.focus();
  }
  function closeMobileMenu() {
    mobileMenu?.classList.remove('open');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', openMobileMenu);
  menuClose?.addEventListener('click', closeMobileMenu);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('open')) closeMobileMenu();
  });

  // Footer newsletter
  const footerForm = document.getElementById('footerNewsletterForm') as HTMLFormElement | null;
  const footerNlSubmit = document.getElementById('footerNlSubmit') as HTMLButtonElement | null;
  const footerEmail = document.getElementById('footerEmail') as HTMLInputElement | null;
  const footerNlMessage = document.getElementById('footerNlMessage');

  footerForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!footerNlSubmit || !footerEmail) return;
    const original = footerNlSubmit.textContent;
    footerNlSubmit.disabled = true;
    footerNlSubmit.textContent = 'Subscribing...';
    try {
      const res = await fetch(footerForm.action, { method: 'POST', body: new FormData(footerForm), headers: { Accept: 'application/json' } });
      if (res.ok) {
        footerForm.reset();
        if (footerNlMessage) footerNlMessage.style.display = 'block';
      }
    } finally {
      footerNlSubmit.disabled = false;
      footerNlSubmit.textContent = original;
    }
  });

  // Fade-in cards on scroll
  const faders = document.querySelectorAll('.post-card, .cat-card, .cat-feature');
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).style.opacity = '1';
          (entry.target as HTMLElement).style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    faders.forEach(el => {
      (el as HTMLElement).style.opacity = '0';
      (el as HTMLElement).style.transform = 'translateY(24px)';
      (el as HTMLElement).style.transition = 'opacity .6s ease, transform .6s ease';
      observer.observe(el);
    });
  }
</script>

</body>
</html>