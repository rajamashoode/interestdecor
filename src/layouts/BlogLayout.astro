---
import BaseLayout from './BaseLayout.astro';
const { post } = Astro.props;
const p = post.data;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: p.title,
  image: new URL(p.heroImage, 'https://interestdecor.com').toString(),
  datePublished: p.date.toISOString().slice(0, 10),
  author: { '@type': 'Person', name: p.author },
  publisher: { '@type': 'Organization', name: 'InterestDecor' },
  description: p.description,
};
---
<BaseLayout
  title={`${p.title} | InterestDecor`}
  description={p.description}
  image={p.heroImage}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- HERO -->
  <section class="blog-hero-detail">
    <div class="blog-hero-bg"></div>
    <div class="container blog-hero-grid">
      <div class="blog-hero-copy">
        <a href="/" class="back-link">← Back to Home</a>
        <span class="article-category">{p.category}</span>
        <h1>{p.title}</h1>
        <p class="article-intro">{p.excerpt}</p>
        <div class="article-meta-line">
          <span>📅 {p.displayDate}</span>
          <span>⏱️ {p.readTime}</span>
          <span>{p.category}</span>
        </div>
      </div>
      <div class="blog-hero-img-outer">
        <div class="blog-hero-image-wrap" style="position:relative;">
          <img
            src={p.heroImage}
            alt={p.heroAlt || p.title}
            width="800"
            height="450"
            data-pin-description={p.heroAlt || p.title}
            data-pin-url={new URL(Astro.url.pathname, 'https://interestdecor.com').toString()}
            data-pin-media={new URL(p.heroImage, 'https://interestdecor.com').toString()}
          />
          <a
            class="pinterest-save"
            href={`https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(new URL(Astro.url.pathname, 'https://interestdecor.com').toString())}&media=${encodeURIComponent(new URL(p.heroImage, 'https://interestdecor.com').toString())}&description=${encodeURIComponent(p.heroAlt || p.title)}`}
            data-pin-media={new URL(p.heroImage, 'https://interestdecor.com').toString()}
            data-pin-description={p.heroAlt || p.title}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Save to Pinterest"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            Save
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <div class="container article-shell">
    <nav class="article-toc" aria-label="Table of contents">
      <p>Contents</p>
      {p.toc.map((item: { label: string; href: string }) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
    <article class="article-content">
      <slot />
    </article>
  </div>
<script>
  const pageUrl = window.location.href;
  document.querySelectorAll('.article-content figure.blog-figure').forEach((figure) => {
    const img = figure.querySelector('img');
    if (!img) return;
    const src = img.getAttribute('src') || '';
    const mediaSrc = src.startsWith('http') ? src : new URL(src, window.location.origin).href;
    const desc = img.alt || document.title;
    img.setAttribute('data-pin-description', desc);
    img.setAttribute('data-pin-url', pageUrl);
    img.setAttribute('data-pin-media', mediaSrc);
    const btn = document.createElement('a');
    btn.className = 'pinterest-save';
    btn.href = `https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(pageUrl)}&media=${encodeURIComponent(mediaSrc)}&description=${encodeURIComponent(desc)}`;
    btn.setAttribute('data-pin-do', 'buttonPin');
    btn.setAttribute('data-pin-custom', 'true');
    btn.setAttribute('data-pin-media', mediaSrc);
    btn.setAttribute('data-pin-description', desc);
    btn.target = '_blank';
    btn.rel = 'noopener noreferrer';
    btn.setAttribute('aria-label', 'Save to Pinterest');
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg> Save`;
    const wrap = figure.querySelector('.blog-image-wrap');
    (wrap || figure).appendChild(btn);
  });
</script>
</BaseLayout>
