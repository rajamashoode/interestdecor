---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
const posts = await getCollection('blog');
---
<BaseLayout
  title="About | InterestDecor"
  description="Learn about InterestDecor — a passion project for home decor, kitchen gardening, floral arrangements and DIY crafts, based in Pakistan."
>

  <div class="page-hero">
    <p class="page-hero-eyebrow">Our Story</p>
    <h1 class="page-hero-title">Made with <em>love</em><br />for beautiful homes</h1>
    <p class="page-hero-desc">InterestDecor is a passion project built on the belief that everyone deserves a home that inspires them — no matter the size or budget.</p>
  </div>

  <section class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-img-wrap" aria-hidden="true">
          <img class="about-img-main" src="/images/about-main.jpg" alt="Cozy InterestDecor workspace" />
          <img class="about-img-accent" src="/images/about-accent.jpg" alt="Soft floral home decor accent" />
        </div>
        <div class="about-content">
          <h2 class="about-name">Hello, I'm the<br />voice behind InterestDecor</h2>
          <p class="about-intro">
            InterestDecor was born from a simple obsession: scrolling Pinterest for hours and then actually <em>making</em> those ideas happen. I'm a home decor enthusiast, reluctant gardener, and forever DIY beginner who documents every project — the wins and the beautiful disasters alike.
          </p>
          <p style="font-size:.9rem; color:var(--muted); line-height:1.9;">
            Based in Pakistan, I write for anyone who believes that a home should feel intentional and loved — wherever you are in the world. Every post here is tested, photographed, and written to be genuinely useful.
          </p>
          <div class="about-stats">
            <div class="stat">
              <span class="stat-num">{posts.length}</span>
              <span class="stat-label">Articles</span>
            </div>
            <div class="stat">
              <span class="stat-num">12k+</span>
              <span class="stat-label">Pinterest Saves</span>
            </div>
            <div class="stat">
              <span class="stat-num">4</span>
              <span class="stat-label">Categories</span>
            </div>
          </div>
          <div class="about-values">
            <p style="font-size:.72rem; font-weight:500; letter-spacing:.16em; text-transform:uppercase; color:var(--rose); margin-bottom:8px;">What I believe</p>
            <div class="about-value"><div class="about-value-dot"></div><span>Great decor doesn't require a big budget — just creativity and intention</span></div>
            <div class="about-value"><div class="about-value-dot"></div><span>Every DIY project teaches you something, even when it goes sideways</span></div>
            <div class="about-value"><div class="about-value-dot"></div><span>Growing things — herbs, flowers, plants — makes any home feel more alive</span></div>
            <div class="about-value"><div class="about-value-dot"></div><span>Your home should tell your story, not copy someone else's</span></div>
          </div>
          <div style="margin-top:16px;">
            <a href="/contact/" class="btn-primary">Get in Touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
